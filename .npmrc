# Configuration pnpm pour Windows
# Ce fichier configure pnpm pour fonctionner correctement sur Windows

# Utiliser le store global de pnpm (plus efficace)
shamefully-hoist=true

# Activer le support des liens symboliques (nécessaire sur Windows)
enable-pre-post-scripts=true

# Configuration du cache (optionnel, pour améliorer les performances)
store-dir=~/.pnpm-store

# Utiliser le format de lockfile strict
lockfile=true

# Configuration pour éviter les problèmes de permissions sur Windows
prefer-frozen-lockfile=false





